# Dependencies — EAS installs fresh
node_modules/

# Expo / Metro caches
.expo/
.expo-shared/

# Git
.git/
.gitignore

# Native build artefacts — EAS rebuilds these
android/build/
android/.gradle/
android/.cxx/
android/app/build/
android/app/.cxx/
android/app/release/
android/app/debug/
android/captures/
ios/build/
ios/Pods/
ios/DerivedData/

# Whole android folder is regenerated by prebuild — exclude it entirely if you don't have native customisations
# Comment this out if you have custom native code in android/ that EAS needs
android/
ios/

# Logs and temp
*.log
.DS_Store
Thumbs.db

# Environment files (already on EAS)
.env.local
.env.development
.env.production

# Documentation / non-build files
*.md
